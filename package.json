{
  "name": "clawreins",
  "version": "0.0.21",
  "description": "ClawReins is the runtime security layer for OpenClaw.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clawreins": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "demo:destructive": "ts-node scripts/demo-destructive.ts",
    "mock:watchtower": "node scripts/mock-watchtower.js",
    "toolshield:sync": "bash ./scripts/sync-toolshield-openclaw.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "security",
    "middleware",
    "ai-agents",
    "openclaw",
    "human-in-the-loop",
    "runtime-interception",
    "zero-trust"
  ],
  "author": "Kevin Wu <kevin@usepegasi.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pegasi-ai/clawreins.git"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "clawreins": "^0.0.21",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.12",
    "scarf": "^0.0.10",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "openclaw.plugin.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": [
      "dist/plugin/index.js"
    ]
  }
}
